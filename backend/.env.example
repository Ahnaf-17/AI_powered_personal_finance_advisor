NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb://localhost:27017/finance_advisor
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# AI — Groq free tier (https://console.groq.com)
# Without a key, budget and savings endpoints fall back to rules-based guidance
# and the chatbot returns a temporary unavailable message.
OPENAI_API_KEY=your_groq_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

# Market data: S&P 500 via Yahoo Finance (no key needed) + BTC via CoinGecko (no key needed)
# Both are 100% free with zero registration required.
